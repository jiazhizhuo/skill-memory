# skill-memory Configuration
# Copy to .env and customize

# ===================
# Backend Configuration
# ===================
# Storage backend: in-memory | qdrant
MEM0_BACKEND=qdrant

# ===================
# LLM Provider
# ===================
# Options: openai | minimax
LLM_PROVIDER=minimax

# ===================
# Embedding Provider
# ===================
# Options: openai | minimax
EMBEDDING_PROVIDER=minimax

# ===================
# API Keys
# ===================
MINIMAX_API_KEY=your_minimax_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ===================
# MiniMax Settings (if using MiniMax)
# ===================
MINIMAX_LLM_BASE_URL=https://api.minimax.io/v1
MINIMAX_LLM_MODEL=MiniMax-M2.7
MINIMAX_EMBEDDING_BASE_URL=https://api.minimax.chat/v1
MINIMAX_EMBEDDING_MODEL=embo-01

# ===================
# Qdrant Settings (if using Qdrant backend)
# ===================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=skill_memory

# ===================
# Search Settings
# ===================
VECTOR_WEIGHT=0.7
KEYWORD_WEIGHT=0.3
DEFAULT_TOP_K=5
MMR_LAMBDA=0.7
TEMPORAL_HALF_LIFE_DAYS=7
