# skill-memory Configuration
# Copy to .env and customize

# ===================
# Storage Configuration
# ===================
# All data is stored at ~/.skill-memory/ (cross-workspace shared)
# Memory: mem0/qdrant storage
# Knowledge: organized knowledge (MEMORY.md, domains, graph)

# ===================
# Backend Configuration
# ===================
# Storage backend: in-memory | qdrant
SKILL_MEMORY_BACKEND=qdrant

# ===================
# LLM Provider
# ===================
# Options: openai | minimax
SKILL_MEMORY_LLM_PROVIDER=minimax

# ===================
# Embedding Provider
# ===================
# Options: openai | minimax
SKILL_MEMORY_EMBEDDING_PROVIDER=minimax

# ===================
# API Keys
# ===================
SKILL_MEMORY_MINIMAX_API_KEY=your_minimax_api_key_here
# SKILL_MEMORY_OPENAI_API_KEY=your_openai_api_key_here

# ===================
# MiniMax Settings (if using MiniMax)
# ===================
SKILL_MEMORY_MINIMAX_LLM_BASE_URL=https://api.minimax.io/v1
SKILL_MEMORY_MINIMAX_LLM_MODEL=MiniMax-M2.7
SKILL_MEMORY_MINIMAX_EMBEDDING_BASE_URL=https://api.minimax.chat/v1
SKILL_MEMORY_MINIMAX_EMBEDDING_MODEL=embo-01

# ===================
# Qdrant Settings (if using Qdrant backend)
# ===================
SKILL_MEMORY_QDRANT_HOST=localhost
SKILL_MEMORY_QDRANT_PORT=6333
SKILL_MEMORY_QDRANT_COLLECTION=skill_memory

# ===================
# Search Settings
# ===================
SKILL_MEMORY_VECTOR_WEIGHT=0.7
SKILL_MEMORY_KEYWORD_WEIGHT=0.3
SKILL_MEMORY_DEFAULT_TOP_K=5
SKILL_MEMORY_MMR_LAMBDA=0.7
SKILL_MEMORY_TEMPORAL_HALF_LIFE_DAYS=7
