# skill-memory Configuration

# ===================
# API Keys (Required)
# ===================
SKILL_MEMORY_API_KEY=your_api_key_here

# ===================
# Provider Configuration
# ===================
SKILL_MEMORY_LLM_PROVIDER=minimax
SKILL_MEMORY_EMBEDDING_PROVIDER=minimax

# ===================
# MiniMax Settings
# ===================
SKILL_MEMORY_MINIMAX_LLM_BASE_URL=https://api.minimaxi.com/v1
SKILL_MEMORY_MINIMAX_LLM_MODEL=MiniMax-M2.5
SKILL_MEMORY_MINIMAX_EMBEDDING_BASE_URL=https://api.minimaxi.com/v1
SKILL_MEMORY_MINIMAX_EMBEDDING_MODEL=embo-01

# ===================
# Qdrant Settings
# ===================
SKILL_MEMORY_QDRANT_HOST=localhost
SKILL_MEMORY_QDRANT_PORT=6333
SKILL_MEMORY_QDRANT_COLLECTION=skill_memory

# ===================
# Search Settings
# ===================
SKILL_MEMORY_DEFAULT_TOP_K=5
SKILL_MEMORY_VECTOR_WEIGHT=0.7
SKILL_MEMORY_KEYWORD_WEIGHT=0.3
